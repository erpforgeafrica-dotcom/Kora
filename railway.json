{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "npm run build",
    "watchPaths": ["**/*"]
  },
  "deploy": {
    "startCommand": "npm start",
    "restartPolicy": {
      "maxRetries": 10
    },
    "healthcheckPath": "/api/health"
  },
  "env": {
    "NODE_ENV": {
      "default": "production"
    },
    "APP_URL": {
      "optional": true
    }
  }
}
