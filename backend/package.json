{
  "name": "kora-backend",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/workers.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "start:worker": "node dist/workers.js",
    "typecheck": "tsc --noEmit",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:migrate:status": "tsx src/db/migrate-status.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:setup": "npm run db:migrate && npm run db:seed",
    "db:reset": "npm run db:migrate:status && echo 'To reset: manually drop and recreate database'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "validate:contracts": "tsx scripts/validate-contracts.ts",
    "coverage:report": "tsx scripts/coverage-report.ts",
    "ai:backfill": "tsx scripts/ai-backfill.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "@clerk/backend": "^1.22.0",
    "@google/genai": "^1.17.0",
    "@mistralai/mistralai": "^1.5.2",
    "@paypal/checkout-server-sdk": "^1.0.3",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.12.15",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "flutterwave-node-v3": "^1.3.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "openai": "^4.104.0",
    "paystack": "^2.0.1",
    "pg": "^8.20.0",
    "stripe": "^20.4.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.12.12",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^6.0.2",
    "openapi-types": "^12.1.3",
    "supertest": "^7.0.0",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5",
    "vitest": "^2.1.4"
  }
}
