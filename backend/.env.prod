# Production Environment
NODE_ENV=production

# Server
PORT=3000

# Database (production instance - high availability)
DATABASE_URL=postgresql://kora_prod:production_secure_password@kora-db-prod.internal:5432/kora_prod

# Redis (production instance - cluster/sentinel)
REDIS_URL=redis://:production_redis_password@kora-redis-prod.internal:6379

# Clerk Authentication (production keys)
CLERK_SECRET_KEY=sk_live_production_key_from_clerk_dashboard
CLERK_AUTHORIZED_PARTIES=https://kora.app,https://app.kora.app

# AI Providers (production keys)
AI_PROVIDER=claude
ANTHROPIC_API_KEY=sk_ant_production_key
OPENAI_API_KEY=sk_production_key
GOOGLE_API_KEY=production_key
MISTRAL_API_KEY=production_key
AI_BUDGET_USD_MONTHLY=5000

# Payment Gateways (live mode)
STRIPE_SECRET_KEY=sk_live_production_key
STRIPE_WEBHOOK_SECRET=whsec_live_production
PAYPAL_MODE=live
PAYPAL_CLIENT_ID=production_client_id
PAYPAL_CLIENT_SECRET=production_secret
FLUTTERWAVE_SECRET_KEY=production_key
PAYSTACK_SECRET_KEY=production_key

# Logging
LOG_LEVEL=warn

# Feature flags
ENABLE_DEMO_MODE=false
ENABLE_MOCK_PAYMENTS=false

# Sentry/Error Tracking
SENTRY_DSN=https://production_key@sentry.io/project_id

# CORS Origins
CORS_ORIGINS=https://kora.app,https://app.kora.app

# Security
ENABLE_RATE_LIMITING=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Database Backups
BACKUP_ENABLED=true
BACKUP_RETENTION_DAYS=30
