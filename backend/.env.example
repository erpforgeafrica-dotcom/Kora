PORT=3000
DATABASE_URL=postgresql://kora:kora@localhost:5432/kora
REDIS_URL=redis://localhost:6379
NODE_ENV=development
LOG_LEVEL=info

# Authentication and sessions
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long-change-in-production
SESSION_SECRET=your-super-secret-session-key-min-32-chars-long-change-in-production
JWT_EXPIRY_HOURS=24
JWT_REFRESH_EXPIRY_DAYS=30
CLERK_SECRET_KEY=your-clerk-backend-secret-min-32-chars-long
CLERK_AUTHORIZED_PARTIES=http://localhost:5173

# Database Connection Pooling
DB_POOL_MAX=20
DB_POOL_MIN=5
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=5000
DB_STATEMENT_TIMEOUT=30000
DB_QUERY_TIMEOUT=30000
SLOW_QUERY_THRESHOLD=1000

# CORS
CORS_ORIGINS=http://localhost:5173

# Feature Flags
ENABLE_DEMO_MODE=true
ENABLE_MOCK_PAYMENTS=true

# API Versioning
API_BASE_URL=http://localhost:3000/api
DEFAULT_API_VERSION=v2

# AI Configuration
AI_PROVIDER=claude
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=
AI_BUDGET_USD_MONTHLY=100

# Workers
ANOMALY_SCAN_INTERVAL_MS=60000
SIGNAL_AGG_INTERVAL_MS=45000
SESSION_CLEANUP_INTERVAL_MS=3600000

# Rate Limiting
VALID_API_KEYS=

# Error Logging & Monitoring
SENTRY_DSN=
DEBUG=false

# Media
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=kora-media-production
AWS_REGION=us-east-1

# Payment Gateways
STRIPE_SECRET_KEY=sk_live_or_test_min_32_chars_placeholder
STRIPE_WEBHOOK_SECRET=whsec_live_or_test_placeholder
STRIPE_WEBHOOK_ENDPOINT=
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=

# Social Media
META_APP_ID=
META_APP_SECRET=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_CLIENT_ID=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
