NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://kora:kora@localhost:5432/kora
REDIS_URL=redis://localhost:6379

# Required secrets (must be set)
JWT_SECRET=dev_jwt_secret_minimum_64_chars_for_security_compliance_requirements
SESSION_SECRET=dev_session_secret_minimum_64_chars_for_security_compliance_req
SENTRY_DSN=

# Auth
CLERK_SECRET_KEY=
CLERK_AUTHORIZED_PARTIES=http://localhost:5173

# AI Configuration
AI_PROVIDER=claude
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=
AI_BUDGET_USD_MONTHLY=100

# Background Jobs
ANOMALY_SCAN_INTERVAL_MS=60000
SIGNAL_AGG_INTERVAL_MS=45000

# Payment Gateways (test keys for dev)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
FLUTTERWAVE_SECRET_KEY=
PAYSTACK_SECRET_KEY=

# Database Connection Pooling
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=5000
DB_STATEMENT_TIMEOUT=30000

# Logging
LOG_LEVEL=debug
DEBUG=true

# CORS
CORS_ORIGINS=http://localhost:5173

# Feature Flags
ENABLE_DEMO_MODE=true
ENABLE_MOCK_PAYMENTS=true

# Rate Limiting
VALID_API_KEYS=dev_api_key_1,dev_api_key_2

# Media Storage (dev)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=kora-media-development
AWS_REGION=us-east-1

# Social Media (dev)
META_APP_ID=
META_APP_SECRET=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_CLIENT_ID=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=