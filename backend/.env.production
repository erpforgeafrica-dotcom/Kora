NODE_ENV=production
PORT=3000

# ── Database (Supabase) ───────────────────────────────────────────────────────
# Use DIRECT connection for migrations, POOLER for runtime
# Get from: Supabase Dashboard → Settings → Database
DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR_DB_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Clerk Auth ────────────────────────────────────────────────────────────────
# Get from: clerk.com/dashboard → API Keys
# ROTATE IMMEDIATELY if previously exposed
CLERK_SECRET_KEY=sk_live_REPLACE_WITH_PRODUCTION_KEY
CLERK_AUTHORIZED_PARTIES=https://yourdomain.com
CLERK_WEBHOOK_SECRET=whsec_REPLACE_WITH_CLERK_WEBHOOK_SECRET

# ── JWT / Session ─────────────────────────────────────────────────────────────
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING
SESSION_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_REPLACE_WITH_LIVE_KEY
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_STRIPE_WEBHOOK_SECRET

# ── AI Configuration ──────────────────────────────────────────────────────────
AI_PROVIDER=claude
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=
AI_BUDGET_USD_MONTHLY=500

# ── Database Connection Pooling ───────────────────────────────────────────────
DB_POOL_MAX=25
DB_POOL_MIN=5
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=5000
DB_STATEMENT_TIMEOUT=30000

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://yourdomain.com

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
SENTRY_DSN=
DEBUG=false

# ── Feature Flags ─────────────────────────────────────────────────────────────
ENABLE_DEMO_MODE=false
ENABLE_MOCK_PAYMENTS=false

# ── Payment Gateways ──────────────────────────────────────────────────────────
PAYPAL_MODE=live
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
FLUTTERWAVE_SECRET_KEY=
PAYSTACK_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=
PAYSTACK_PUBLIC_KEY=

# ── Media ─────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=kora-media-production
AWS_REGION=us-east-1

# ── Workers ───────────────────────────────────────────────────────────────────
ANOMALY_SCAN_INTERVAL_MS=300000
SIGNAL_AGG_INTERVAL_MS=180000

# ── Social ────────────────────────────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_CLIENT_ID=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
