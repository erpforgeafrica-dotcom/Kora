NODE_ENV=production
PORT=3000
DATABASE_URL=
REDIS_URL=

# REQUIRED: Must be set in production
JWT_SECRET=
SESSION_SECRET=
SENTRY_DSN=

# Auth (production keys)
CLERK_SECRET_KEY=
CLERK_AUTHORIZED_PARTIES=

# AI Configuration
AI_PROVIDER=claude
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=
AI_BUDGET_USD_MONTHLY=500

# Background Jobs
ANOMALY_SCAN_INTERVAL_MS=300000
SIGNAL_AGG_INTERVAL_MS=180000

# Payment Gateways (live keys)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAL_MODE=live
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
FLUTTERWAVE_SECRET_KEY=
PAYSTACK_SECRET_KEY=

# Database Connection Pooling (production)
DB_POOL_MAX=25
DB_POOL_MIN=5
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=5000
DB_STATEMENT_TIMEOUT=30000

# Logging
LOG_LEVEL=info
DEBUG=false

# CORS (production domains)
CORS_ORIGINS=

# Feature Flags
ENABLE_DEMO_MODE=false
ENABLE_MOCK_PAYMENTS=false

# Rate Limiting
VALID_API_KEYS=

# Media Storage (production)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=kora-media-production
AWS_REGION=us-east-1

# Social Media (production)
META_APP_ID=
META_APP_SECRET=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_CLIENT_ID=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=