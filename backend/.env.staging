# Staging Environment
NODE_ENV=staging

# Server
PORT=3000

# Database (staging instance)
DATABASE_URL=postgresql://kora_staging:secure_password@kora-db-staging:5432/kora_staging

# Redis (staging instance)
REDIS_URL=redis://:redis_password@kora-redis-staging:6379

# Clerk Authentication
CLERK_SECRET_KEY=sk_test_staging_key_from_clerk_dashboard
CLERK_AUTHORIZED_PARTIES=https://staging.kora.app

# AI Providers (staging keys)
AI_PROVIDER=claude
ANTHROPIC_API_KEY=sk_ant_staging_key
OPENAI_API_KEY=sk_staging_key
GOOGLE_API_KEY=staging_key
MISTRAL_API_KEY=staging_key
AI_BUDGET_USD_MONTHLY=500

# Payment Gateways (test mode)
STRIPE_SECRET_KEY=sk_test_staging_key
STRIPE_WEBHOOK_SECRET=whsec_test_staging
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=staging_client_id
PAYPAL_CLIENT_SECRET=staging_secret
FLUTTERWAVE_SECRET_KEY=staging_key
PAYSTACK_SECRET_KEY=staging_key

# Logging
LOG_LEVEL=info

# Feature flags
ENABLE_DEMO_MODE=false
ENABLE_MOCK_PAYMENTS=false

# Sentry/Error Tracking (optional)
SENTRY_DSN=https://staging_key@sentry.io/project_id

# CORS Origins
CORS_ORIGINS=https://staging.kora.app,https://admin-staging.kora.app
