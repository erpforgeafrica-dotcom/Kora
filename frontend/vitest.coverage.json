{
  "coverage": {
    "provider": "v8",
    "reporter": ["text", "json", "html"],
    "exclude": [
      "node_modules/",
      "src/test/",
      "**/*.d.ts",
      "**/*.config.*",
      "**/coverage/**"
    ],
    "thresholds": {
      "global": {
        "branches": 90,
        "functions": 90,
        "lines": 95,
        "statements": 95
      },
      "src/components/ui/": {
        "branches": 95,
        "functions": 95,
        "lines": 95,
        "statements": 95
      },
      "src/services/": {
        "branches": 90,
        "functions": 90,
        "lines": 90,
        "statements": 90
      }
    }
  }
}