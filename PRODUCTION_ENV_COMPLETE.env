# ===================================================================
# KORA PLATFORM - COMPLETE ENVIRONMENT CONFIGURATION
# Ready for direct upload to Render/Vercel/Railway deployment
# ===================================================================

# ── Core Application ──────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Database (Supabase) ───────────────────────────────────────────
DATABASE_URL=postgresql://postgres.zihocnhvtgodnawnvoyj:KoraDB2024secure@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

# ── Redis (Required for Threat Detection) ────────────────────────
REDIS_URL=redis://localhost:6379

# ── Security & Sessions ───────────────────────────────────────────
JWT_SECRET=<generate-32-char-random-string>
SESSION_SECRET=<generate-32-char-random-string>

# ── Clerk Authentication ──────────────────────────────────────────
CLERK_SECRET_KEY=<your-clerk-key>
CLERK_AUTHORIZED_PARTIES=https://<your-frontend-render-url>
CLERK_WEBHOOK_SECRET=<your-clerk-webhook>

# ── Stripe Payments ───────────────────────────────────────────────
STRIPE_SECRET_KEY=<your-stripe-key>
STRIPE_WEBHOOK_SECRET=<your-stripe-webhook>

# ── CORS & API Configuration ──────────────────────────────────────
CORS_ORIGINS=https://<your-frontend-render-url>
API_BASE_URL=https://<your-backend-render-url>/api
DEFAULT_API_VERSION=v2

# ── AI Configuration ──────────────────────────────────────────────
AI_PROVIDER=claude
ANTHROPIC_API_KEY=<your-key>
OPENAI_API_KEY=<your-key>
GOOGLE_API_KEY=<optional>
MISTRAL_API_KEY=<optional>
AI_BUDGET_USD_MONTHLY=100

# ── 🛡️ THREAT DETECTION SYSTEM ──────────────────────────────────
# Core Settings
THREAT_DETECTION_ENABLED=true
AUTO_RESPONSE_ENABLED=true
ANOMALY_SCAN_INTERVAL_MS=60000
SIGNAL_AGG_INTERVAL_MS=45000

# Detection Thresholds (0-100 confidence scores)
SQL_INJECTION_THRESHOLD=85
CROSS_ORG_THRESHOLD=90
BRUTE_FORCE_THRESHOLD=70
IMPOSSIBLE_TRAVEL_THRESHOLD=75
DATA_EXFIL_THRESHOLD=75
PRIVILEGE_ESC_THRESHOLD=80
TOKEN_ANOMALY_THRESHOLD=65
RATE_LIMIT_THRESHOLD=70

# Auto-Response Configuration
AUTO_REVOKE_SESSION_THRESHOLD=85
AUTO_BLOCK_IP_THRESHOLD=80
AUTO_LOCK_ACCOUNT_THRESHOLD=95
IP_BLOCK_DURATION_MS=86400000
MAX_FAILED_ATTEMPTS_PER_IP=10

# Security Logging
SECURITY_LOG_LEVEL=info
THREAT_LOG_RETENTION_DAYS=90
AUDIT_LOG_ENABLED=true

# Feature Flags - Threat Detectors
ENABLE_SQL_INJECTION_DETECTION=true
ENABLE_CROSS_ORG_DETECTION=true
ENABLE_BRUTE_FORCE_DETECTION=true
ENABLE_IMPOSSIBLE_TRAVEL=true
ENABLE_DATA_EXFILTRATION_DETECTION=true
ENABLE_PRIVILEGE_ESCALATION_DETECTION=true
ENABLE_TOKEN_ANOMALY_DETECTION=true
ENABLE_RATE_LIMIT_DETECTION=true

# Security Dashboard
ENABLE_SECURITY_DASHBOARD=true
ENABLE_REAL_TIME_ALERTS=true
ENABLE_INCIDENT_MANAGEMENT=true

# ── Database Connection Pooling ───────────────────────────────────
DB_POOL_MAX=20
DB_POOL_MIN=5
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=10000
DB_STATEMENT_TIMEOUT=30000
DB_QUERY_TIMEOUT=30000
SLOW_QUERY_THRESHOLD=1000

# ── Logging & Monitoring ──────────────────────────────────────────
LOG_LEVEL=info
SENTRY_DSN=<optional>
DEBUG=false

# ── Workers & Background Jobs ─────────────────────────────────────
ENABLE_WORKERS=true
WORKER_CONCURRENCY=5
QUEUE_REDIS_URL=redis://localhost:6379

# ── Feature Flags ─────────────────────────────────────────────────
ENABLE_DEMO_MODE=false
ENABLE_MOCK_PAYMENTS=false

# ── Payment Gateways ──────────────────────────────────────────────
PAYPAL_MODE=live
PAYPAL_CLIENT_ID=<your-paypal-client-id>
PAYPAL_CLIENT_SECRET=<your-paypal-secret>
FLUTTERWAVE_SECRET_KEY=<your-flutterwave-key>
PAYSTACK_SECRET_KEY=<your-paystack-key>

# ── Media & File Storage ──────────────────────────────────────────
AWS_ACCESS_KEY_ID=<your-aws-key>
AWS_SECRET_ACCESS_KEY=<your-aws-secret>
AWS_S3_BUCKET=kora-media-production
AWS_REGION=us-east-1

# ── Social Media Integration ──────────────────────────────────────
META_APP_ID=<your-meta-app-id>
META_APP_SECRET=<your-meta-secret>
WHATSAPP_PHONE_NUMBER_ID=<your-whatsapp-id>
WHATSAPP_ACCESS_TOKEN=<your-whatsapp-token>
TWITTER_API_KEY=<your-twitter-key>
TWITTER_API_SECRET=<your-twitter-secret>
TIKTOK_CLIENT_KEY=<your-tiktok-key>
TIKTOK_CLIENT_SECRET=<your-tiktok-secret>

# ── Security Notifications ────────────────────────────────────────
SECURITY_TEAM_EMAIL=security@yourcompany.com
SLACK_SECURITY_WEBHOOK=<your-slack-webhook>
PAGERDUTY_INTEGRATION_KEY=<optional>

# ── Performance & Limits ──────────────────────────────────────────
THREAT_PROCESSING_TIMEOUT_MS=5000
MAX_EVENTS_PER_BATCH=100
EVENT_QUEUE_MAX_SIZE=10000
ALERT_COOLDOWN_MS=300000

# ===================================================================
# DEPLOYMENT NOTES:
# 
# 1. Replace all <placeholder> values with actual keys/URLs
# 2. Generate secure random strings for JWT_SECRET and SESSION_SECRET
# 3. Update URLs to match your actual deployment domains
# 4. Set Redis URL to your Redis instance (or use Redis addon)
# 5. Configure Clerk, Stripe, and AI provider keys
# 
# THREAT DETECTION READY:
# - All threat detection variables configured
# - Auto-response enabled with safe thresholds
# - Security dashboard enabled
# - Complete monitoring and alerting setup
# ===================================================================